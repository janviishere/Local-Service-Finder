generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String    @unique
  password  String
  role      String    @default("customer") // 'customer', 'provider', or 'admin'
  phone     String?
  avatar    String?
  address   String?
  city      String?
  latitude  Float?
  longitude Float?
  createdAt DateTime  @default(now())

  services         Service[]        // For providers
  bookings         Booking[]        // For customers
  reviews          Review[]         // For customers
  favorites        Favorite[]       // Favorited services
  providerProfile  ProviderProfile?
  sentMessages     ChatMessage[]    @relation("SentMessages")
  receivedMessages ChatMessage[]    @relation("ReceivedMessages")
}

model ProviderProfile {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  userId             String   @unique @db.ObjectId
  user               User     @relation(fields: [userId], references: [id])

  tagline            String?
  bio                String?
  yearsOfExperience  Int?
  certifications     String?  // JSON array of strings
  documents          String?  // JSON array of { name, url }
  serviceRadius      Float?   // in km
  subscriptionPlan   String   @default("basic") // basic, pro, premium
  verificationStatus String   @default("approved")
  isAvailable        Boolean  @default(true)
  availabilitySlots  String?  // JSON: { "mon": ["09:00","10:00"...], "tue": [...] }

  // Service area location
  serviceArea        String?
  serviceLatitude    Float?
  serviceLongitude   Float?

  // Stats (updated on booking complete)
  totalEarnings      Float    @default(0)
  completedJobs      Int      @default(0)

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Category {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  slug        String    @unique
  icon        String?
  description String?
  image       String?
  services    Service[]
}

model Service {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  title            String
  description      String?
  price            String
  image            String?
  portfolioImages  String?   // JSON array of image URLs
  rating           Float     @default(0)
  reviewCount      Int       @default(0)
  duration         String?
  city             String?
  isActive         Boolean   @default(true)
  latitude         Float?
  longitude        Float?

  categoryId  String?   @db.ObjectId
  category    Category? @relation(fields: [categoryId], references: [id])

  providerId  String    @db.ObjectId
  provider    User      @relation(fields: [providerId], references: [id])

  bookings    Booking[]
  reviews     Review[]
  favoritedBy Favorite[]

  createdAt   DateTime  @default(now())
}

model Review {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  rating    Int
  comment   String?

  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])

  serviceId String   @db.ObjectId
  service   Service  @relation(fields: [serviceId], references: [id])

  createdAt DateTime @default(now())
}

model Booking {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  date        String
  time        String
  status      String   @default("Upcoming") // Upcoming, Confirmed, In Progress, Completed, Cancelled
  address     String?
  latitude    Float?
  longitude   Float?
  notes       String?
  totalPrice  String?

  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id])

  serviceId   String   @db.ObjectId
  service     Service  @relation(fields: [serviceId], references: [id])

  messages    ChatMessage[]
  payment     Payment?

  createdAt   DateTime @default(now())
}

model Favorite {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  userId    String  @db.ObjectId
  user      User    @relation(fields: [userId], references: [id])
  serviceId String  @db.ObjectId
  service   Service @relation(fields: [serviceId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, serviceId])
}

model ChatMessage {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  message    String
  createdAt  DateTime @default(now())

  bookingId  String   @db.ObjectId
  booking    Booking  @relation(fields: [bookingId], references: [id])

  senderId   String   @db.ObjectId
  sender     User     @relation("SentMessages", fields: [senderId], references: [id])

  receiverId String   @db.ObjectId
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
}

model Payment {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  bookingId       String   @unique @db.ObjectId
  booking         Booking  @relation(fields: [bookingId], references: [id])

  amount          Float
  depositAmount   Float    @default(0)
  depositPaid     Boolean  @default(false)
  fullPaid        Boolean  @default(false)
  paymentMethod   String?  // card, upi, wallet
  transactionId   String?
  status          String   @default("pending") // pending, deposit_paid, completed, refunded
  invoiceNumber   String?
  taxAmount       Float    @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
