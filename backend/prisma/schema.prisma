generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  password  String
  role      String    @default("customer") // 'customer' or 'provider'
  createdAt DateTime  @default(now())
  
  services  Service[] // For providers
  bookings  Booking[] // For customers
}

model Service {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  price       String
  providerId  Int
  provider    User      @relation(fields: [providerId], references: [id])
  bookings    Booking[]
  createdAt   DateTime  @default(now())
}

model Booking {
  id        Int      @id @default(autoincrement())
  date      String
  time      String
  status    String   @default("Upcoming")
  
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  
  serviceId Int
  service   Service  @relation(fields: [serviceId], references: [id])
  
  createdAt DateTime @default(now())
}
